<?xml version="1.0"?>
<labwc_config>
  <core>
    <!-- Use client-side decorations by default so GTK4/Qt apps render their own
         rounded corners and shadows. SSD can be forced per-app via windowRules. -->
    <decoration>client</decoration>
  </core>
  <workspaces>
    <workspace name="1" />
    <workspace name="2" />
    <workspace name="3" />
    <workspace name="4" />
  </workspaces>
  <keyboard>
    <!-- Window management -->
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="W-a">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="A-Space">
      <action name="ShowMenu">
        <menu>client-menu</menu>
        <atCursor>no</atCursor>
      </action>
    </keybind>

    <!-- Singularity shortcuts (via D-Bus) -->
    <keybind key="W-Return">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'spawn_terminal'"</command>
      </action>
    </keybind>
    <!-- Tap Super alone to open launcher -->
    <keybind key="Super_L" onRelease="yes">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'toggle_launcher'"</command>
      </action>
    </keybind>
    <keybind key="W-space">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'toggle_launcher'"</command>
      </action>
    </keybind>
    <keybind key="A-S-F2">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'run_command'"</command>
      </action>
    </keybind>
    <keybind key="W-r">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'retile_windows'"</command>
      </action>
    </keybind>
    <keybind key="W-m">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_mute'"</command>
      </action>
    </keybind>
    <keybind key="W-Up">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_up'"</command>
      </action>
    </keybind>
    <keybind key="W-Down">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_down'"</command>
      </action>
    </keybind>
    <keybind key="W-Right">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'brightness_up'"</command>
      </action>
    </keybind>
    <keybind key="W-Left">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'brightness_down'"</command>
      </action>
    </keybind>

    <!-- Media keys -->
    <keybind key="XF86_AudioRaiseVolume">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_up'"</command>
      </action>
    </keybind>
    <keybind key="XF86_AudioLowerVolume">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_down'"</command>
      </action>
    </keybind>
    <keybind key="XF86_AudioMute">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'volume_mute'"</command>
      </action>
    </keybind>
    <keybind key="XF86_MonBrightnessUp">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'brightness_up'"</command>
      </action>
    </keybind>
    <keybind key="XF86_MonBrightnessDown">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'brightness_down'"</command>
      </action>
    </keybind>
    <keybind key="XF86_KbdBrightnessUp">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'kbd_brightness_up'"</command>
      </action>
    </keybind>
    <keybind key="XF86_KbdBrightnessDown">
      <action name="Execute">
        <command>gdbus call --session --dest dev.sinty.desktop --object-path /dev/sinty/desktop/Shortcuts --method dev.sinty.desktop.Shortcuts.ExecuteAction "'kbd_brightness_down'"</command>
      </action>
    </keybind>
  </keyboard>
</labwc_config>
