# Window title / frame
window.active.title.bg.color: #2d2d2e
window.active.title.bg: flat
window.active.label.text.color: #ffffff
window.active.border.color: #444444
window.active.handle.bg.color: #2d2d2e
window.active.handle.bg: flat
window.active.grip.bg.color: #2d2d2e
window.active.grip.bg: flat

window.inactive.title.bg.color: #1e1e1f
window.inactive.title.bg: flat
window.inactive.label.text.color: #888888
