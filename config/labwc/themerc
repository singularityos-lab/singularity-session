window.inactive.handle.bg: flat
window.inactive.grip.bg.color: #1e1e1f
window.inactive.grip.bg: flat

# Buttons
window.active.button.unpressed.image.color: #cccccc
window.active.button.hover.image.color: #ffffff
window.inactive.button.unpressed.image.color: #555555

# Shadows
window.active.shadow.size: 40
window.inactive.shadow.size: 28
window.active.shadow.color: #00000055
window.inactive.shadow.color: #00000030
